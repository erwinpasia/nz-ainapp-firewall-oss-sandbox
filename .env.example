# ─── AI Firewall Configuration ────────────────────────────────────────────────
AI_FIREWALL_ADDR=127.0.0.1:11435
OLLAMA_REAL_URL=http://127.0.0.1:11434
AI_FIREWALL_SEMANTIC_THRESHOLD=0.70
AI_FIREWALL_INSPECT_OUTPUT=true
AI_FIREWALL_BYPASS_SECRET=sentinel-internal-bypass-2024
NEXT_PUBLIC_DEFAULT_CHAT_MODEL=nemotron-3-nano:4b


# ─── PostgreSQL Database (OSS Sandbox Backend) ────────────────────────────────
# Port 5432 is confirmed vacant on host. Update password in production.
POSTGRES_PASSWORD=changeme_local
DATABASE_URL=postgresql://postgres:changeme_local@127.0.0.1:5432/ai_firewall
